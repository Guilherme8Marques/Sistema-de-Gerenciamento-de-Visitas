{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": false,
        "skipLibCheck": true,
        "outDir": "./dist",
        "rootDir": ".",
        "resolveJsonModule": true,
        "declaration": true,
        "typeRoots": [
            "../node_modules/@types",
            "."
        ]
    },
    "include": [
        "./**/*.ts",
        "./sql-js.d.ts"
    ],
    "exclude": [
        "dist"
    ]
}